{
  "license": "MIT",
  "publish": {
    "include": ["./**/*.ts", "./README.md", "./LICENSE", "./deno.json"]
  },
  "tasks": {
    "test": "deno test -A ./ledger.integration.test.ts",
    "ledger:start": "deno run -A ./start-ledger.ts",
    "ledger:start:log": "deno run -A ./start-ledger.ts --logs",
    "ledger:transactions": "deno run -A ./run-transactions.ts",
    "ledger:transactions:log": "deno run -A ./run-transactions.ts --logs",
    "ledger:restart": "deno run -A ./restart-ledger.ts",
    "ledger:restart:log": "deno run -A ./restart-ledger.ts --logs",
    "ledger:stop": "deno run -A ./stop-ledger.ts",
    "ledger:stop:log": "deno run -A ./stop-ledger.ts --logs"
  }
}
